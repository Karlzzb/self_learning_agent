# ──────────────────────────────────────────────────────────────────────────
# Self-Learning Agent — 环境配置模板
# 用法:cp .env.example .env,然后填入真实密钥。.env 已被 .gitignore 忽略。
# 密钥由调用方/运营提供;智能体永不自管账号/鉴权/计费。
# ──────────────────────────────────────────────────────────────────────────

# ── 模型层(承接「模型是一个可换旋钮」原则)─────────────────────────────
# 默认 provider。切换默认模型只需改这一处,业务节点代码完全不动。
# 可选:qwen(默认,DashScope/百炼)| anthropic(切到 Claude 的口子)
LLM_PROVIDER=qwen

# 所有节点的默认温度(单节点差异化温度后续按需添加)
LLM_TEMPERATURE=0.7

# ── Qwen via DashScope(默认 provider)──────────────────────────────────
# 百炼控制台获取;走 OpenAI 兼容端点。
DASHSCOPE_API_KEY=sk-replace-me
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Claude(可选,LLM_PROVIDER=anthropic 时启用)────────────────────────
ANTHROPIC_API_KEY=

# ── 搜索层(ADR-0007 极简工具面;承接「搜索源藏在可换接口后」)──────────
# MVP 默认 = 百炼内置 enable_search,**不需要独立密钥**(复用 DASHSCOPE_API_KEY)。
# 换搜索提供方只改这一处 / 调 search.set_provider,业务节点零改动。
SEARCH_PROVIDER=dashscope
# 单次检索返回的候选条数上限(甄别前的原始候选)。
SEARCH_MAX_RESULTS=8

# ── Langfuse 逐节点链路追踪(self-hosted;ADR-0016 取代 LangSmith)──────
# 走 LangChain 回调机制,由 observability.get_callbacks() 接线。留空/置 false
# 即关闭(此时完全不 import langfuse);无数据出境约束,开发与生产皆可用。
LANGFUSE_TRACING=true
LANGFUSE_HOST=http://10.15.231.165:13000
LANGFUSE_PUBLIC_KEY=pk-lf-replace-me
LANGFUSE_SECRET_KEY=sk-lf-replace-me
